# ─── Langflow ────────────────────────────────────────────────────────────────
# Senha do superusuário criado automaticamente na primeira execução
LANGFLOW_SUPERUSER_PASSWORD=admin

# Gerada automaticamente pelo container langflow-init (não edite manualmente)
LANGFLOW_API_KEY=

# ─── LLM Providers ───────────────────────────────────────────────────────────
# Obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Obtenha em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
